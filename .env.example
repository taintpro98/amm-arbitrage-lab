# Deployer (without 0x prefix is also accepted)
PRIVATE_KEY=

# Docker Compose `deploy` service only: override Anvil test key (default is account #0)
# DEPLOY_PRIVATE_KEY=

# Local chain (Hardhat node, Anvil in Docker, etc.)
LOCAL_RPC_URL=http://127.0.0.1:8545
LOCAL_CHAIN_ID=31337

# Public RPCs (examples — use your provider)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Etherscan / explorer API for contract verification (same key works for many EVM explorers via Hardhat)
ETHERSCAN_API_KEY=

# Optional: gas / deploy tuning
# GAS_PRICE_GWEI=
